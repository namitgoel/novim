{
  "name": "novim",
  "version": "0.1.0",
  "description": "A hybrid terminal multiplexer and modal text editor",
  "main": "dist/index.js",
  "bin": {
    "novim": "./dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
